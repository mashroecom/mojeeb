apiVersion: v1
kind: Secret
metadata:
  name: mojeeb-secrets
  namespace: mojeeb
type: Opaque
stringData:
  # ========================
  # Application
  # ========================
  NODE_ENV: "production"
  API_PORT: "4000"
  FRONTEND_URL: "REPLACE_WITH_FRONTEND_URL"  # e.g., https://mojeeb.app
  API_URL: "REPLACE_WITH_API_URL"  # e.g., https://api.mojeeb.app
  NEXT_PUBLIC_API_URL: "REPLACE_WITH_API_URL/api/v1"  # e.g., https://api.mojeeb.app/api/v1

  # ========================
  # Database
  # ========================
  # Format: postgresql://username:password@host:port/database?schema=public
  DATABASE_URL: "postgresql://mojeeb:REPLACE_WITH_DB_PASSWORD@postgres:5432/mojeeb?schema=public"
  POSTGRES_PASSWORD: "REPLACE_WITH_DB_PASSWORD"  # Generate: openssl rand -base64 32

  # ========================
  # Redis
  # ========================
  REDIS_URL: "redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379"
  REDIS_PASSWORD: "REPLACE_WITH_REDIS_PASSWORD"  # Generate: openssl rand -base64 32

  # ========================
  # JWT Authentication
  # ========================
  # Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
  JWT_SECRET: "REPLACE_WITH_JWT_SECRET"  # Minimum 32 characters
  JWT_ACCESS_EXPIRY: "15m"
  JWT_REFRESH_EXPIRY: "7d"

  # ========================
  # Encryption
  # ========================
  # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
  ENCRYPTION_KEY: "REPLACE_WITH_ENCRYPTION_KEY"  # 64 hex characters (32 bytes)

  # ========================
  # AI Providers
  # ========================
  # Get your key from https://platform.openai.com/api-keys
  OPENAI_API_KEY: "REPLACE_WITH_OPENAI_API_KEY"
  # Get your key from https://console.anthropic.com/settings/keys
  ANTHROPIC_API_KEY: "REPLACE_WITH_ANTHROPIC_API_KEY"

  # ========================
  # Meta Platform (WhatsApp, Messenger, Instagram)
  # ========================
  META_APP_SECRET: "REPLACE_WITH_META_APP_SECRET"
  META_VERIFY_TOKEN: "REPLACE_WITH_META_VERIFY_TOKEN"
  WHATSAPP_ACCESS_TOKEN: "REPLACE_WITH_WHATSAPP_ACCESS_TOKEN"
  WHATSAPP_PHONE_NUMBER_ID: "REPLACE_WITH_WHATSAPP_PHONE_NUMBER_ID"
  MESSENGER_PAGE_ACCESS_TOKEN: "REPLACE_WITH_MESSENGER_PAGE_ACCESS_TOKEN"
  INSTAGRAM_ACCESS_TOKEN: "REPLACE_WITH_INSTAGRAM_ACCESS_TOKEN"

  # ========================
  # Kashier Payment
  # ========================
  KASHIER_MERCHANT_ID: "REPLACE_WITH_KASHIER_MERCHANT_ID"
  KASHIER_API_KEY: "REPLACE_WITH_KASHIER_API_KEY"
  KASHIER_WEBHOOK_SECRET: "REPLACE_WITH_KASHIER_WEBHOOK_SECRET"

  # ========================
  # Email
  # ========================
  # Get your key from https://resend.com/api-keys
  RESEND_API_KEY: "REPLACE_WITH_RESEND_API_KEY"
  EMAIL_FROM: "noreply@mojeeb.app"

  # ========================
  # Google OAuth
  # ========================
  # Get from https://console.cloud.google.com/apis/credentials
  GOOGLE_CLIENT_ID: "REPLACE_WITH_GOOGLE_CLIENT_ID"
  GOOGLE_CLIENT_SECRET: "REPLACE_WITH_GOOGLE_CLIENT_SECRET"
  NEXT_PUBLIC_GOOGLE_CLIENT_ID: "REPLACE_WITH_GOOGLE_CLIENT_ID"
