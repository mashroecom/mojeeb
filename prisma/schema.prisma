generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// AUTH & ORGANIZATION
// ========================

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  passwordHash         String
  firstName            String
  lastName             String
  avatarUrl            String?
  isSuperAdmin         Boolean   @default(false)
  suspendedAt          DateTime?
  emailVerified        Boolean   @default(false)
  emailVerifiedAt      DateTime?
  emailVerifyToken     String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  lastLoginAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  memberships            OrgMembership[]
  sentMessages           Message[]            @relation("HumanAgentMessages")
  sessions               Session[]
  apiKeys                ApiKey[]
  notifications          Notification[]
  verificationTokens     VerificationToken[]
  auditLogs              AuditLog[]           @relation("AuditLogs")
  announcements          Announcement[]       @relation("CreatedAnnouncements")
  notificationPreferences NotificationPreference[]
  assignedLeads          Lead[]               @relation("AssignedLeads")
  loginActivities        LoginActivity[]
  blockedIPs             BlockedIP[]          @relation("BlockedIPs")
  bulkEmailCampaigns     BulkEmailCampaign[]  @relation("BulkEmailCampaigns")
  adminNotifications     AdminNotification[]  @relation("AdminNotifications")

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

model Organization {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  logoUrl         String?
  websiteUrl      String?
  industry        String?
  timezone        String    @default("Asia/Riyadh")
  defaultLanguage String    @default("ar")
  suspendedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  members                 OrgMembership[]
  agents                  Agent[]
  channels                Channel[]
  conversations           Conversation[]
  knowledgeBases          KnowledgeBase[]
  subscription            Subscription?
  apiKeys                 ApiKey[]
  leads                   Lead[]
  analyticsEvents         AnalyticsEvent[]
  notifications           Notification[]
  webhooks                Webhook[]
  notificationPreferences NotificationPreference[]
  messageTemplates        MessageTemplate[]

  @@map("organizations")
}

model OrgMembership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role      OrgRole  @default(MEMBER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_memberships")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// ========================
// AI AGENTS
// ========================

model Agent {
  id                     String     @id @default(cuid())
  orgId                  String
  org                    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name                   String
  description            String?
  aiProvider             AiProvider @default(OPENAI)
  aiModel                String     @default("gpt-4o")
  systemPrompt           String     @db.Text
  temperature            Float      @default(0.7)
  maxTokens              Int        @default(1024)
  language               String     @default("ar")
  isActive               Boolean    @default(true)
  enableEmotionDetection Boolean    @default(true)
  enableLeadExtraction   Boolean    @default(false)
  enableHumanHandoff     Boolean    @default(true)
  handoffThreshold       Float      @default(0.3)
  templateType           String?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  knowledgeBases AgentKnowledgeBase[]
  channels       ChannelAgent[]
  conversations  Conversation[]

  @@index([orgId])
  @@map("agents")
}

enum AiProvider {
  OPENAI
  ANTHROPIC
}

// ========================
// KNOWLEDGE BASE
// ========================

model KnowledgeBase {
  id          String   @id @default(cuid())
  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents KBDocument[]
  agents    AgentKnowledgeBase[]

  @@index([orgId])
  @@map("knowledge_bases")
}

model KBDocument {
  id              String          @id @default(cuid())
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  title           String
  content         String          @db.Text
  contentType     KBDocumentType  @default(TEXT)
  sourceUrl       String?
  metadata        Json?
  embeddingStatus EmbeddingStatus @default(PENDING)
  chunkCount      Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  chunks KBChunk[]

  @@index([knowledgeBaseId])
  @@map("kb_documents")
}

model KBChunk {
  id         String     @id @default(cuid())
  documentId String
  document   KBDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  content    String     @db.Text
  embedding  Unsupported("vector(1536)")?
  chunkIndex Int
  metadata   Json?
  createdAt  DateTime   @default(now())

  @@index([documentId])
  @@map("kb_chunks")
}

model AgentKnowledgeBase {
  agentId         String
  agent           Agent         @relation(fields: [agentId], references: [id], onDelete: Cascade)
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@id([agentId, knowledgeBaseId])
  @@map("agent_knowledge_bases")
}

enum KBDocumentType {
  TEXT
  PDF
  URL
  FAQ
}

enum EmbeddingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ========================
// CHANNELS
// ========================

model Channel {
  id            String      @id @default(cuid())
  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  type          ChannelType
  name          String
  isActive      Boolean     @default(false)
  credentials   Json
  webhookSecret String?
  externalId    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  agents        ChannelAgent[]
  conversations Conversation[]

  @@unique([orgId, type, externalId])
  @@index([orgId])
  @@index([webhookSecret])
  @@map("channels")
}

model ChannelAgent {
  channelId String
  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  agentId   String
  agent     Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isPrimary Boolean @default(false)

  @@id([channelId, agentId])
  @@map("channel_agents")
}

enum ChannelType {
  WHATSAPP
  MESSENGER
  INSTAGRAM
  WEBCHAT
}

// ========================
// CONVERSATIONS & MESSAGES
// ========================

model Conversation {
  id              String             @id @default(cuid())
  orgId           String
  org             Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  channelId       String
  channel         Channel            @relation(fields: [channelId], references: [id])
  agentId         String?
  agent           Agent?             @relation(fields: [agentId], references: [id])
  customerId      String
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  customerMeta    Json?
  status          ConversationStatus @default(ACTIVE)
  assignedToHuman String?
  lastEmotion     String?
  emotionScore    Float?
  summary         String?            @db.Text
  messageCount    Int                @default(0)
  firstMessageAt  DateTime           @default(now())
  lastMessageAt   DateTime           @default(now())
  resolvedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  messages Message[]
  leads    Lead[]
  tags     ConversationTag[]
  ratings  ConversationRating[]
  notes    ConversationNote[]

  @@index([orgId, status])
  @@index([orgId, channelId])
  @@index([orgId, lastMessageAt])
  @@index([customerId, channelId])
  @@index([channelId])
  @@index([agentId])
  @@map("conversations")
}

model Message {
  id             String             @id @default(cuid())
  conversationId String
  conversation   Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String             @db.Text
  contentType    MessageContentType @default(TEXT)
  humanAgentId   String?
  humanAgent     User?              @relation("HumanAgentMessages", fields: [humanAgentId], references: [id])
  aiProvider     AiProvider?
  aiModel        String?
  tokenCount     Int?
  latencyMs      Int?
  emotion        String?
  emotionScore   Float?
  externalId     String?
  metadata       Json?
  deliveryStatus DeliveryStatus     @default(SENT)
  deliveredAt    DateTime?
  readAt         DateTime?
  failureReason  String?
  createdAt      DateTime           @default(now())

  @@index([conversationId, createdAt])
  @@index([externalId])
  @@index([humanAgentId])
  @@index([role])
  @@map("messages")
}

enum ConversationStatus {
  ACTIVE
  HANDED_OFF
  WAITING
  RESOLVED
  ARCHIVED
}

enum MessageRole {
  CUSTOMER
  AI_AGENT
  HUMAN_AGENT
  SYSTEM
}

enum MessageContentType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  LOCATION
  CONTACT
  TEMPLATE
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

// ========================
// CONVERSATION TAGS
// ========================

model Tag {
  id        String            @id @default(cuid())
  orgId     String
  name      String
  color     String            @default("#6366f1")
  createdAt DateTime          @default(now())

  conversations ConversationTag[]

  @@unique([orgId, name])
  @@index([orgId])
  @@map("tags")
}

model ConversationTag {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tagId          String
  tag            Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([conversationId, tagId])
  @@map("conversation_tags")
}

// ========================
// CSAT RATINGS
// ========================

model ConversationRating {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  rating         Int          // 1-5
  feedback       String?      @db.Text
  customerId     String
  createdAt      DateTime     @default(now())

  @@unique([conversationId, customerId])
  @@index([conversationId])
  @@map("conversation_ratings")
}

// ========================
// LEADS
// ========================

model Lead {
  id             String        @id @default(cuid())
  orgId          String
  org            Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  assignedTo     String?
  assignedUser   User?         @relation("AssignedLeads", fields: [assignedTo], references: [id])
  name           String?
  email          String?
  phone          String?
  company        String?
  interests      String[]
  budget         String?
  timeline       String?
  notes          String?       @db.Text
  confidence     Float         @default(0.0)
  source         String?
  status         LeadStatus    @default(NEW)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  activities LeadActivity[]

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([conversationId])
  @@index([assignedTo])
  @@map("leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

// ========================
// DEMO REQUESTS
// ========================

model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  company   String?
  message   String?  @db.Text
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("demo_requests")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String   @db.Text
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ========================
// SUBSCRIPTIONS & BILLING
// ========================

model Subscription {
  id                    String             @id @default(cuid())
  orgId                 String             @unique
  org                   Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  kashierSubscriptionId String?            @unique
  kashierCustomerId     String?
  currentPeriodStart    DateTime           @default(now())
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean            @default(false)
  messagesUsed          Int                @default(0)
  messagesLimit         Int                @default(100)
  agentsUsed            Int                @default(0)
  agentsLimit           Int                @default(1)
  integrationsUsed      Int                @default(0)
  integrationsLimit     Int                @default(1)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  invoices Invoice[]

  @@map("subscriptions")
}

model Invoice {
  id               String        @id @default(cuid())
  subscriptionId   String
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount           Decimal       @db.Decimal(10, 2)
  currency         String        @default("USD")
  status           InvoiceStatus @default(PENDING)
  kashierOrderId   String?       @unique
  kashierPaymentId String?
  paidAt           DateTime?
  dueDate          DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([subscriptionId])
  @@map("invoices")
}

enum SubscriptionPlan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ========================
// API KEYS
// ========================

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId      String
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique
  keyPrefix  String
  lastUsedAt DateTime?
  expiresAt  DateTime?
  scopes     String[]
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([orgId])
  @@index([keyHash])
  @@index([keyHash, revokedAt])
  @@map("api_keys")
}

// ========================
// ANALYTICS
// ========================

model AnalyticsEvent {
  id          String             @id @default(cuid())
  orgId       String
  org         Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  eventType   AnalyticsEventType
  data        Json
  channelType ChannelType?
  agentId     String?
  date        DateTime           @default(now()) @db.Date
  createdAt   DateTime           @default(now())

  @@index([orgId, eventType, date])
  @@index([orgId, date])
  @@map("analytics_events")
}

enum AnalyticsEventType {
  MESSAGE_RECEIVED
  MESSAGE_SENT
  CONVERSATION_STARTED
  CONVERSATION_RESOLVED
  HUMAN_HANDOFF
  LEAD_EXTRACTED
  EMOTION_DETECTED
  AI_RESPONSE_GENERATED
}

// ========================
// NOTIFICATIONS
// ========================

model Notification {
  id        String   @id @default(cuid())
  orgId     String
  userId    String
  type      String   // CONVERSATION_NEW, CONVERSATION_HANDOFF, LEAD_NEW, USAGE_WARNING, SYSTEM
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?    // optional data (conversationId, leadId, etc.)
  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([orgId])
  @@map("notifications")
}

// ========================
// VERIFICATION TOKENS
// ========================

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  type      String    // EMAIL_VERIFY, PASSWORD_RESET
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId, type])
  @@map("verification_tokens")
}

// ========================
// AUDIT LOG
// ========================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("AuditLogs", fields: [userId], references: [id], onDelete: Cascade)
  action     String
  targetType String
  targetId   String
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ========================
// ANNOUNCEMENTS
// ========================

model Announcement {
  id        String    @id @default(cuid())
  title     String
  body      String    @db.Text
  type      String    @default("INFO") // INFO, WARNING, CRITICAL
  isActive  Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdBy String
  creator   User      @relation("CreatedAnnouncements", fields: [createdBy], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isActive, startsAt])
  @@map("announcements")
}

// ========================
// NOTIFICATION PREFERENCES
// ========================

model NotificationPreference {
  id                   String       @id @default(cuid())
  orgId                String
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId               String
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNewConversation Boolean      @default(true)
  emailHandoff         Boolean      @default(true)
  emailLeadExtracted   Boolean      @default(true)
  emailUsageWarning    Boolean      @default(true)
  emailWeeklyDigest    Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@unique([orgId, userId])
  @@map("notification_preferences")
}

// ========================
// WEBHOOKS
// ========================

model Webhook {
  id              String       @id @default(cuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  url             String
  secret          String
  events          String[]
  isActive        Boolean      @default(true)
  lastError       String?
  lastTriggeredAt DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  logs WebhookLog[]

  @@index([orgId])
  @@map("webhooks")
}

// ========================
// LEAD ACTIVITY
// ========================

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String?
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([leadId, createdAt])
  @@map("lead_activities")
}

// ========================
// SITE SETTINGS (singleton)
// ========================

model SiteSettings {
  id                 String   @id @default("singleton")
  siteName           String   @default("Mojeeb")
  logoUrl            String?
  faviconUrl         String?
  ogImageUrl         String?
  description        String   @default("")
  keywords           String   @default("")
  primaryColor       String   @default("#6366f1")
  secondaryColor     String   @default("#ec4899")
  twitterUrl         String?
  linkedinUrl        String?
  githubUrl          String?
  facebookUrl        String?
  instagramUrl       String?
  youtubeUrl         String?
  supportEmail       String?
  contactPhone       String?
  companyAddress     String?
  copyrightText      String?
  timezone           String   @default("UTC")
  googleAnalyticsId  String?
  customHeadScripts  String?
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("site_settings")
}

// ========================
// PLAN CONFIGURATION
// ========================

model PlanConfig {
  id                String           @id @default(cuid())
  plan              SubscriptionPlan @unique
  displayName       String
  displayNameAr     String           @default("")
  monthlyPrice      Float            @default(0)
  yearlyPrice       Float            @default(0)
  currency          String           @default("USD")
  messagesPerMonth  Int              @default(100)
  maxAgents         Int              @default(1)
  maxChannels       Int              @default(1)
  maxKnowledgeBases Int              @default(0)
  maxTeamMembers    Int              @default(1)
  apiAccess         Boolean          @default(false)
  isPopular         Boolean          @default(false)
  sortOrder         Int              @default(0)
  features          String           @default("[]")
  featuresAr        String           @default("[]")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("plan_configs")
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @default("")
  category    String   @default("general")
  isSecret    Boolean  @default(false)
  label       String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("system_configs")
}

// ========================
// LOGIN ACTIVITY LOG
// ========================

model LoginActivity {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email      String
  success    Boolean
  ipAddress  String?
  userAgent  String?
  country    String?
  city       String?
  failReason String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([success, createdAt])
  @@map("login_activities")
}

// ========================
// IP BLOCKING
// ========================

model BlockedIP {
  id        String    @id @default(cuid())
  ip        String    @unique
  reason    String
  blockedBy String
  blocker   User      @relation("BlockedIPs", fields: [blockedBy], references: [id])
  autoBlock Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())

  @@index([ip])
  @@index([expiresAt])
  @@map("blocked_ips")
}

// ========================
// FEATURE FLAGS
// ========================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(false)
  description String   @default("")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}

// ========================
// ERROR LOGS
// ========================

model ErrorLog {
  id        String   @id @default(cuid())
  level     String   @default("ERROR")
  message   String
  stack     String?  @db.Text
  source    String?
  path      String?
  method    String?
  userId    String?
  ipAddress String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([level, createdAt])
  @@index([source, createdAt])
  @@index([createdAt])
  @@map("error_logs")
}

// ========================
// WEBHOOK DELIVERY LOGS
// ========================

model WebhookLog {
  id           String   @id @default(cuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String
  status       Int?
  requestBody  String?  @db.Text
  responseBody String?  @db.Text
  duration     Int?
  attempt      Int      @default(1)
  error        String?
  success      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([webhookId, createdAt])
  @@index([success, createdAt])
  @@index([event, createdAt])
  @@map("webhook_logs")
}

// ========================
// EMAIL TEMPLATES
// ========================

model EmailTemplate {
  id         String   @id @default(cuid())
  key        String   @unique
  subject    String
  subjectAr  String   @default("")
  bodyHtml   String   @db.Text
  bodyHtmlAr String   @default("") @db.Text
  bodyText   String?  @db.Text
  variables  String[]
  isActive   Boolean  @default(true)
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("email_templates")
}

// ========================
// BULK EMAIL CAMPAIGNS
// ========================

model BulkEmailCampaign {
  id              String    @id @default(cuid())
  subject         String
  bodyHtml        String    @db.Text
  status          String    @default("DRAFT")
  targetFilter    Json
  totalRecipients Int       @default(0)
  sentCount       Int       @default(0)
  failedCount     Int       @default(0)
  createdBy       String
  creator         User      @relation("BulkEmailCampaigns", fields: [createdBy], references: [id])
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("bulk_email_campaigns")
}

// ========================
// ADMIN NOTIFICATIONS
// ========================

model AdminNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("AdminNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, isRead, createdAt])
  @@map("admin_notifications")
}

// ========================
// LANDING PAGE CONTENT
// ========================

model LandingPageContent {
  id                  String   @id @default("singleton")
  heroTitle           String   @default("AI-Powered Customer Support")
  heroTitleAr         String   @default("دعم العملاء بالذكاء الاصطناعي")
  heroSubtitle        String   @default("Automate your customer support with intelligent AI agents")
  heroSubtitleAr      String   @default("أتمت دعم العملاء مع وكلاء ذكاء اصطناعي")
  heroCta             String   @default("Get Started Free")
  heroCtaAr           String   @default("ابدأ مجاناً")
  heroCtaLink         String   @default("/register")
  featuresTitle       String   @default("Why Choose Mojeeb?")
  featuresTitleAr     String   @default("لماذا تختار مجيب؟")
  features            Json     @default("[]")
  featuresAr          Json     @default("[]")
  statsEnabled        Boolean  @default(true)
  testimonialsEnabled Boolean  @default(true)
  testimonials        Json     @default("[]")
  testimonialsAr      Json     @default("[]")
  pricingTitle        String   @default("Simple, Transparent Pricing")
  pricingTitleAr      String   @default("أسعار بسيطة وشفافة")
  pricingSubtitle     String   @default("Choose the plan that fits your business")
  pricingSubtitleAr   String   @default("اختر الخطة المناسبة لعملك")
  footerText          String   @default("© 2025 Mojeeb. All rights reserved.")
  footerTextAr        String   @default("© 2025 مجيب. جميع الحقوق محفوظة.")
  customCss           String?  @db.Text
  updatedAt           DateTime @updatedAt

  @@map("landing_page_content")
}

// ========================
// CONVERSATION NOTES
// ========================

model ConversationNote {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  content        String       @db.Text
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId, createdAt])
  @@map("conversation_notes")
}

// ========================
// MESSAGE TEMPLATES
// ========================

model MessageTemplate {
  id        String   @id @default(cuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  title     String
  content   String   @db.Text
  category  String?
  shortcut  String?
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@map("message_templates")
}
