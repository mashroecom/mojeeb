# ========================
# Application
# ========================
NODE_ENV=development
API_PORT=4000
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
# Production frontend env (set at build time):
# NEXT_PUBLIC_API_URL=https://api.mojeeb.app/api/v1

# ========================
# Database
# ========================
# For local dev with docker/docker-compose.yml defaults:
DATABASE_URL=postgresql://mojeeb:password@localhost:5432/mojeeb?schema=public
# Production: use a strong password, e.g. postgresql://mojeeb:STRONG_PASSWORD@postgres:5432/mojeeb

# ========================
# Redis
# ========================
# For local dev with docker/docker-compose.yml defaults:
REDIS_URL=redis://:devpassword@localhost:6379
# Production: use REDIS_PASSWORD env var and redis://:YOUR_PASSWORD@redis:6379

# ========================
# Docker (used by docker-compose.prod.yml)
# ========================
# POSTGRES_PASSWORD=          # REQUIRED in production. Generate: openssl rand -base64 32
# REDIS_PASSWORD=             # REQUIRED in production. Generate: openssl rand -base64 32

# ========================
# JWT Authentication
# ========================
# REQUIRED: Generate a strong random secret (minimum 32 characters).
# Run: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=CHANGE_ME_generate_a_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ========================
# Encryption
# ========================
# REQUIRED: 64 hex characters (32 bytes). Used for encrypting sensitive data at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_ME_run_node_e_require_crypto_randomBytes_32_toString_hex

# ========================
# AI Providers
# ========================
# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ========================
# Meta Platform (WhatsApp, Messenger, Instagram)
# ========================
META_APP_SECRET=
META_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# ========================
# Kashier Payment
# ========================
KASHIER_MERCHANT_ID=
KASHIER_API_KEY=
KASHIER_WEBHOOK_SECRET=

# ========================
# Email
# ========================
# Get your key from https://resend.com/api-keys
RESEND_API_KEY=
EMAIL_FROM=noreply@mojeeb.app

# ========================
# Google OAuth
# ========================
# Get from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
